# LLM Provider: "anthropic", "openai", or "google"
LLM_PROVIDER=google
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
GOOGLE_GENERATIVE_AI_API_KEY=...
# LLM_MODEL=gemini-2.0-flash  # optional, defaults per provider

# Merchant
MERCHANT_URL=http://localhost:2337

# Wallet (0x-prefixed private key with USDC on Arc Testnet, chainId 5042002)
# Fund it at https://faucet.circle.com (select Arc Testnet); USDC covers gas AND payments
WALLET_PRIVATE_KEY=0x...

# Chain (Arc testnet defaults)
X402_CHAIN=arc-testnet
X402_CURRENCY=USDC
# Optional RPC override (defaults to https://rpc.testnet.arc.network)
# ARC_RPC_URL=https://rpc.testnet.arc.network

# StreamPay payment channel contract (set after deploy)
# STREAMPAY_ADDRESS=0x...

# ERC-8004 Trustless Identity (optional, set after first on-chain registration)
# ERC8004_AGENT_ID=1

# Behavior
MAX_STEPS=20
AUTO_APPROVE_PAYMENTS=false
VERBOSE=true
