# ==============================================
# DEPLOY — Domain for Caddy auto-SSL
# ==============================================
# The domain whose A record points at this VM. Caddy provisions Let's
# Encrypt certificates automatically for this host (and www.<host>).
SUPERPAGE_DOMAIN=superpa.ge

# ==============================================
# BACKEND — Server
# ==============================================
PORT=2337
PAYMENT_SERVER_PORT=3337
NODE_ENV=production

# Public URLs (used for OAuth callbacks, agent card, CORS, etc.)
APP_URL=https://superpa.ge
FRONTEND_URL=https://superpa.ge

# Internal URL the backend's MCP handler uses for server-to-server calls.
# Inside the docker network, the app container's hostname is "superpage".
BACKEND_URL=http://superpage:2337

# ==============================================
# BACKEND — MongoDB
# ==============================================
# In docker-compose this is overridden to mongodb://mongo:27017/x402 by
# the compose `environment:` block. Leave the value here for docs.
MONGODB_URI=mongodb://mongo:27017/x402

# ==============================================
# BACKEND — JWT
# ==============================================
JWT_SECRET=CHANGE_ME_RANDOM_SECRET

# ==============================================
# BACKEND — Shopify OAuth
# Redirect URL to whitelist in Shopify Partners app config:
#   https://YOUR_DOMAIN/api/shopify/callback
# ==============================================
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_CLIENT_SECRET=your-shopify-client-secret

# ==============================================
# BACKEND — Wallet / Payment (Mezo Testnet / matsnet)
# Native gas: BTC (18 dec)  •  Default payment token: MUSD (18 dec, BTC-backed)
# Mezo testnet BTC faucet: https://mezo.org/matsnet/faucet
# ==============================================
ETH_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
WALLET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
X402_RECIPIENT_ADDRESS=0xYOUR_RECIPIENT_ADDRESS
ETH_RECIPIENT_ADDRESS=0xYOUR_RECIPIENT_ADDRESS
X402_CHAIN=mezo-testnet
X402_CURRENCY=MUSD

# ==============================================
# BACKEND — ERC-8004 Trustless Agents
# ==============================================
ERC8004_AGENT_ID=0

# ==============================================
# FRONTEND — Build args (NEXT_PUBLIC_* baked at build time)
# Must match APP_URL above so the bundle calls the right host.
# ==============================================
NEXT_PUBLIC_API_URL=https://superpa.ge
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id
NEXT_PUBLIC_X402_CHAIN=mezo-testnet
NEXT_PUBLIC_X402_CURRENCY=MUSD
